# Optional override for the backend wallet API base URL.
# Default: '/api' which is proxied to http://localhost:3000 by vite.config.js.
# Set this only if you want to bypass the dev proxy and hit the API directly
# (the backend must allow CORS for your dev origin in that case).
# VITE_API_BASE_URL=http://localhost:3000

# Optional override for the dev proxy target used by vite.config.js.
# Default: http://localhost:3000
# VITE_API_TARGET=http://localhost:3000
